#!/usr/bin/env python3
import argparse
import base64
import json
import os
import pathlib
import re
import struct
import subprocess
import sys
import tempfile
import time
import zlib


CURSOR_BITMAP = [
    "X...........",
    "XX..........",
    "X.X.........",
    "X..X........",
    "X...X.......",
    "X....X......",
    "X.....X.....",
    "X......X....",
    "X.......X...",
    "X........X..",
    "X.....XXXX..",
    "X..X..X.....",
    "X.X.X..X....",
    "XX..X..X....",
    "X....X..X...",
    ".....X..X...",
    "......XX....",
]


def _chunk(kind: bytes, data: bytes) -> bytes:
    return struct.pack(">I", len(data)) + kind + data + struct.pack(">I", zlib.crc32(kind + data) & 0xFFFFFFFF)


def rgba_to_png(width: int, height: int, rgba: bytes) -> bytes:
    if width <= 0 or height <= 0:
        raise ValueError("invalid image dimensions")
    expected = width * height * 4
    if len(rgba) != expected:
        raise ValueError(f"rgba byte count mismatch: got {len(rgba)}, expected {expected}")

    rows = bytearray()
    stride = width * 4
    for y in range(height):
        rows.append(0)
        start = y * stride
        rows.extend(rgba[start : start + stride])

    return b"".join(
        [
            b"\x89PNG\r\n\x1a\n",
            _chunk(b"IHDR", struct.pack(">IIBBBBB", width, height, 8, 6, 0, 0, 0)),
            _chunk(b"IDAT", zlib.compress(bytes(rows), 6)),
            _chunk(b"IEND", b""),
        ]
    )


def state_root(output_dir: str | None = None) -> pathlib.Path:
    root = pathlib.Path(output_dir or tempfile.gettempdir()) / f"hypr-agent-protal-{os.getuid()}"
    root.mkdir(mode=0o700, parents=True, exist_ok=True)
    return root


def cursor_state_path(output_dir: str | None = None) -> pathlib.Path:
    return state_root(output_dir) / "cursor.json"


def finite_float(value) -> float | None:
    try:
        number = float(value)
    except (TypeError, ValueError):
        return None
    if number != number or number in (float("inf"), float("-inf")):
        return None
    return number


def read_agent_cursor(path: pathlib.Path) -> dict | None:
    try:
        data = json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return None

    x = finite_float(data.get("x"))
    y = finite_float(data.get("y"))
    if x is None or y is None:
        return None
    return {**data, "x": x, "y": y}


def write_agent_cursor(path: pathlib.Path, *, target: str, x: float, y: float, action: str, button: str) -> None:
    path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    tmp = path.with_suffix(".tmp")
    payload = {
        "x": float(x),
        "y": float(y),
        "target": target,
        "action": action,
        "button": button,
        "timestamp": time.time(),
    }
    tmp.write_text(json.dumps(payload, ensure_ascii=False))
    tmp.replace(path)


def select_cursor_position(session: dict, source: str, cursor_path: pathlib.Path) -> tuple[dict | None, str]:
    if source == "none":
        return None, "none"

    agent_cursor = read_agent_cursor(cursor_path)
    if source in {"auto", "agent"} and agent_cursor is not None:
        return {"x": agent_cursor["x"], "y": agent_cursor["y"]}, "agent"

    if source == "agent":
        return None, "agent"

    compositor_cursor = session.get("cursorPosition")
    if isinstance(compositor_cursor, dict):
        x = finite_float(compositor_cursor.get("x"))
        y = finite_float(compositor_cursor.get("y"))
        if x is not None and y is not None:
            return {"x": x, "y": y}, "hyprland"

    return None, "hyprland" if source == "hyprland" else "none"


def blend_pixel(canvas: bytearray, width: int, height: int, x: int, y: int, color: tuple[int, int, int, int]) -> None:
    if x < 0 or y < 0 or x >= width or y >= height:
        return

    r, g, b, a = color
    idx = (y * width + x) * 4
    if a >= 255:
        canvas[idx : idx + 4] = bytes((r, g, b, 255))
        return

    inv = 255 - a
    canvas[idx] = (r * a + canvas[idx] * inv) // 255
    canvas[idx + 1] = (g * a + canvas[idx + 1] * inv) // 255
    canvas[idx + 2] = (b * a + canvas[idx + 2] * inv) // 255
    canvas[idx + 3] = 255


def blend_rect(canvas: bytearray, width: int, height: int, x: int, y: int, size: int, color: tuple[int, int, int, int]) -> None:
    for yy in range(y, y + size):
        for xx in range(x, x + size):
            blend_pixel(canvas, width, height, xx, yy, color)


def draw_cursor_indicator(canvas: bytearray, width: int, height: int, x: int, y: int, scale: float) -> None:
    unit = max(1, min(3, round(scale)))
    fill_cells = [(cx, cy) for cy, row in enumerate(CURSOR_BITMAP) for cx, value in enumerate(row) if value == "X"]
    fill_set = set(fill_cells)

    shadow_offset = max(1, unit)
    for cx, cy in fill_cells:
        blend_rect(canvas, width, height, x + shadow_offset + cx * unit, y + shadow_offset + cy * unit, unit, (0, 0, 0, 80))

    for cx, cy in fill_cells:
        for oy in (-1, 0, 1):
            for ox in (-1, 0, 1):
                if (cx + ox, cy + oy) not in fill_set:
                    blend_rect(canvas, width, height, x + (cx + ox) * unit, y + (cy + oy) * unit, unit, (255, 255, 255, 230))

    for cx, cy in fill_cells:
        blend_rect(canvas, width, height, x + cx * unit, y + cy * unit, unit, (18, 18, 18, 245))


def render_session_png(session: dict, *, cursor_source: str = "none", cursor_path: pathlib.Path | None = None) -> tuple[bytes, dict]:
    monitors = [m for m in session.get("monitors", []) if m.get("artifactPath") and m.get("artifactWidth") and m.get("artifactHeight")]
    if not monitors:
        raise RuntimeError("no rendered monitor artifacts in screenshot session")

    min_x = min(float(m["geometry"]["x"]) for m in monitors)
    min_y = min(float(m["geometry"]["y"]) for m in monitors)
    max_x = max(float(m["geometry"]["x"]) + float(m["geometry"]["width"]) for m in monitors)
    max_y = max(float(m["geometry"]["y"]) + float(m["geometry"]["height"]) for m in monitors)
    out_scale = max(float(m.get("scale") or 1.0) for m in monitors)
    out_w = max(1, round((max_x - min_x) * out_scale))
    out_h = max(1, round((max_y - min_y) * out_scale))
    canvas = bytearray(out_w * out_h * 4)

    for m in monitors:
        src_w = int(m["artifactWidth"])
        src_h = int(m["artifactHeight"])
        raw = pathlib.Path(m["artifactPath"]).read_bytes()
        if len(raw) != src_w * src_h * 4:
            raise RuntimeError(f"invalid artifact size for {m['artifactPath']}")

        geom = m["geometry"]
        dst_x = round((float(geom["x"]) - min_x) * out_scale)
        dst_y = round((float(geom["y"]) - min_y) * out_scale)
        dst_w = max(1, round(float(geom["width"]) * out_scale))
        dst_h = max(1, round(float(geom["height"]) * out_scale))

        for y in range(dst_h):
            sy = min(src_h - 1, int(y * src_h / dst_h))
            out_y = dst_y + y
            if out_y < 0 or out_y >= out_h:
                continue
            for x in range(dst_w):
                sx = min(src_w - 1, int(x * src_w / dst_w))
                out_x = dst_x + x
                if out_x < 0 or out_x >= out_w:
                    continue
                src_i = (sy * src_w + sx) * 4
                dst_i = (out_y * out_w + out_x) * 4
                canvas[dst_i : dst_i + 4] = raw[src_i : src_i + 4]

    indicator_position = None
    indicator_source = "none"
    indicator_pixel = None
    if cursor_path is not None:
        indicator_position, indicator_source = select_cursor_position(session, cursor_source, cursor_path)
        if indicator_position is not None:
            cursor_x = float(indicator_position["x"])
            cursor_y = float(indicator_position["y"])
            if min_x <= cursor_x <= max_x and min_y <= cursor_y <= max_y:
                pixel_x = round((cursor_x - min_x) * out_scale)
                pixel_y = round((cursor_y - min_y) * out_scale)
                draw_cursor_indicator(canvas, out_w, out_h, pixel_x, pixel_y, out_scale)
                indicator_pixel = {"x": pixel_x, "y": pixel_y}

    metadata = {
        "width": out_w,
        "height": out_h,
        "scale": out_scale,
        "logicalBounds": {"x": min_x, "y": min_y, "width": max_x - min_x, "height": max_y - min_y},
        "cursorPosition": indicator_position or session.get("cursorPosition"),
        "compositorCursorPosition": session.get("cursorPosition"),
        "cursorIndicator": {
            "enabled": cursor_source != "none",
            "visible": indicator_pixel is not None,
            "source": indicator_source,
            "position": indicator_position,
            "pixelPosition": indicator_pixel,
        },
        "windows": session.get("windows", []),
        "monitors": [
            {
                "name": m.get("name"),
                "geometry": m.get("geometry"),
                "scale": m.get("scale"),
                "artifactWidth": m.get("artifactWidth"),
                "artifactHeight": m.get("artifactHeight"),
            }
            for m in monitors
        ],
    }
    return rgba_to_png(out_w, out_h, bytes(canvas)), metadata


def hyprctl_environment() -> dict[str, str]:
    env = os.environ.copy()
    env.setdefault("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    if env.get("HYPRLAND_INSTANCE_SIGNATURE"):
        return env

    proc = subprocess.run(["hyprctl", "instances", "-j"], text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, env=env, check=False)
    if proc.returncode == 0 and proc.stdout.strip():
        try:
            instances = json.loads(proc.stdout)
        except json.JSONDecodeError:
            instances = []

        if instances:
            wayland_display = env.get("WAYLAND_DISPLAY")
            matching = [item for item in instances if wayland_display and item.get("wl_socket") == wayland_display]
            selected = max(matching or instances, key=lambda item: int(item.get("time") or 0))
            if selected.get("instance"):
                env["HYPRLAND_INSTANCE_SIGNATURE"] = str(selected["instance"])
            if not env.get("WAYLAND_DISPLAY") and selected.get("wl_socket"):
                env["WAYLAND_DISPLAY"] = str(selected["wl_socket"])
            return env

    runtime_root = pathlib.Path(env["XDG_RUNTIME_DIR"]) / "hypr"
    sockets = sorted(runtime_root.glob("*/.socket.sock"), key=lambda path: path.stat().st_mtime, reverse=True)
    if sockets:
        env["HYPRLAND_INSTANCE_SIGNATURE"] = sockets[0].parent.name
    return env


def dispatch(*args: str) -> subprocess.CompletedProcess:
    return subprocess.run(["hyprctl", "dispatch", *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=hyprctl_environment(), check=False)


def hyprctl(*args: str) -> subprocess.CompletedProcess:
    return subprocess.run(["hyprctl", *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=hyprctl_environment(), check=False)


def screenshot(args: argparse.Namespace) -> int:
    root = state_root(args.output_dir)
    session_path = root / f"session-{time.time_ns()}.json"

    payload = str(session_path)
    if args.target:
        payload = ",".join([payload, args.target])
    result = dispatch(args.dispatcher, payload)
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1
    if not session_path.exists():
        print(f"screenshot session json was not written: {session_path}", file=sys.stderr)
        return 1

    session = json.loads(session_path.read_text())
    cursor_source = "none" if args.no_cursor else args.cursor_source
    png, metadata = render_session_png(session, cursor_source=cursor_source, cursor_path=root / "cursor.json")

    png_path = session_path.with_suffix(".png")
    png_path.write_bytes(png)
    metadata.update({"sessionPath": str(session_path), "pngPath": str(png_path)})

    if args.base64:
        metadata["pngBase64"] = base64.b64encode(png).decode("ascii")
    print(json.dumps(metadata, ensure_ascii=False))
    return 0


def pointer(args: argparse.Namespace) -> int:
    payload = ",".join([args.target, str(args.x), str(args.y), args.action, args.button])
    if args.action == "scroll" and args.dx is not None:
        payload = ",".join([args.target, str(args.x), str(args.y), args.action, args.button, str(args.dx)])
    elif args.action == "drag":
        if args.x2 is None or args.y2 is None:
            print("drag requires x2 and y2", file=sys.stderr)
            return 2
        payload = ",".join([args.target, str(args.x), str(args.y), args.action, args.button, str(args.x2), str(args.y2), str(max(0.0, min(args.duration, 3.0)))])
    result = dispatch(args.dispatcher, payload)
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1
    cursor_x = args.x2 if args.action == "drag" and args.x2 is not None else args.x
    cursor_y = args.y2 if args.action == "drag" and args.y2 is not None else args.y
    write_agent_cursor(cursor_state_path(), target=args.target, x=cursor_x, y=cursor_y, action=args.action, button=args.button)
    if args.json:
        print(
            json.dumps(
                {
                    "ok": True,
                    "target": args.target,
                    "x": args.x,
                    "y": args.y,
                    "x2": args.x2,
                    "y2": args.y2,
                    "action": args.action,
                    "button": args.button,
                    "duration": args.duration,
                }
            )
        )
    else:
        print(result.stdout, end="")
    return 0


def indicator(args: argparse.Namespace) -> int:
    payload = ",".join([args.target, str(args.x), str(args.y), args.action])
    result = dispatch(args.dispatcher, payload)
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1
    write_agent_cursor(cursor_state_path(), target=args.target, x=args.x, y=args.y, action=args.action, button="left")
    if args.json:
        print(json.dumps({"ok": True, "target": args.target, "x": args.x, "y": args.y, "action": args.action}))
    else:
        print(result.stdout, end="")
    return 0


def keyboard(args: argparse.Namespace) -> int:
    parts = [args.target, args.action, args.key, args.modifiers or ""]
    if args.x is not None or args.y is not None:
        if args.x is None or args.y is None:
            print("--x and --y must be passed together", file=sys.stderr)
            return 2
        parts.extend([str(args.x), str(args.y)])

    result = dispatch(args.dispatcher, ",".join(parts))
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1
    if args.x is not None and args.y is not None:
        write_agent_cursor(cursor_state_path(), target=args.target, x=args.x, y=args.y, action="key", button="left")
    if args.json:
        print(json.dumps({"ok": True, "target": args.target, "action": args.action, "key": args.key, "modifiers": args.modifiers or ""}))
    else:
        print(result.stdout, end="")
    return 0


def session(args: argparse.Namespace) -> int:
    parts = [args.action]
    if args.target:
        parts.append(args.target)

    result = dispatch(args.dispatcher, ",".join(parts))
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1
    if args.json:
        print(json.dumps({"ok": True, "action": args.action, "target": args.target or ""}))
    else:
        print(result.stdout, end="")
    return 0


def windows(args: argparse.Namespace) -> int:
    result = hyprctl("clients", "-j")
    if result.returncode != 0:
        print(result.stderr or result.stdout, file=sys.stderr, end="")
        return result.returncode or 1

    clients = json.loads(result.stdout or "[]")
    related_to = None
    if args.related_to:
        related_to = next((client for client in clients if selector_matches(client, args.related_to)), None)
        if related_to is None:
            print(f"related target not found: {args.related_to}", file=sys.stderr)
            return 1

    if args.visible_workspace:
        active = hyprctl("activeworkspace", "-j")
        workspace = None
        if active.returncode == 0 and active.stdout.strip():
            workspace = json.loads(active.stdout).get("id")
        if workspace is not None:
            clients = [c for c in clients if (c.get("workspace") or {}).get("id") == workspace]

    if related_to is not None:
        clients = [annotate_relation(client, related_to) for client in clients if is_related_window(client, related_to)]

    print(json.dumps({"windows": clients}, ensure_ascii=False))
    return 0


def selector_matches(client: dict, selector: str) -> bool:
    selector = selector.strip()
    if selector.startswith("address:"):
        return str(client.get("address", "")).lower() == selector.split(":", 1)[1].lower()
    haystack = "\n".join(str(client.get(key, "")) for key in ["address", "class", "title", "initialClass", "initialTitle"])
    try:
        return re.search(selector, haystack) is not None
    except re.error:
        return selector in haystack


def is_related_window(client: dict, target: dict) -> bool:
    if client.get("address") == target.get("address"):
        return True
    if not client.get("mapped", True) or client.get("hidden", False):
        return False
    return bool(client.get("pid") and client.get("pid") == target.get("pid"))


def annotate_relation(client: dict, target: dict) -> dict:
    annotated = dict(client)
    if client.get("address") == target.get("address"):
        annotated["hyprAgentProtalRelation"] = "self"
        return annotated

    annotated["hyprAgentProtalRelation"] = "related"
    tx, ty = target.get("at") or [0, 0]
    tw, th = target.get("size") or [0, 0]
    x, y = client.get("at") or [0, 0]
    w, h = client.get("size") or [0, 0]
    target_area = max(1.0, float(tw) * float(th))
    area = max(1.0, float(w) * float(h))
    if area < target_area * 0.6 and x >= tx - 64 and y >= ty - 64 and x <= tx + tw + 64 and y <= ty + th + 64:
        annotated["hyprAgentProtalWindowKind"] = "popup"
    else:
        annotated["hyprAgentProtalWindowKind"] = "related"
    return annotated


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="hypr-agent-protal command line bridge")
    sub = parser.add_subparsers(dest="cmd", required=True)

    shot = sub.add_parser("screenshot", help="capture a compositor screenshot session")
    shot.add_argument("--dispatcher", default="hypr-agent-protal:screenshot")
    shot.add_argument("--output-dir")
    shot.add_argument("--target", help="optional Hyprland window selector for unoccluded target-window capture")
    shot.add_argument("--base64", action="store_true")
    shot.add_argument("--no-cursor", action="store_true", help="do not draw the cursor indicator on the returned PNG")
    shot.add_argument(
        "--cursor-source",
        choices=["auto", "agent", "hyprland", "none"],
        default="none",
        help="debug PNG cursor indicator source; auto prefers the last background pointer coordinate",
    )
    shot.set_defaults(func=screenshot)

    ptr = sub.add_parser("pointer", help="send pointer input to a target window")
    ptr.add_argument("target", help="Hyprland window regex, for example address:0x1234")
    ptr.add_argument("x", type=float, help="global logical x coordinate")
    ptr.add_argument("y", type=float, help="global logical y coordinate")
    ptr.add_argument("action", choices=["move", "motion", "click", "doubleclick", "double-click", "press", "down", "release", "up", "scroll", "drag"])
    ptr.add_argument("button", nargs="?", default="left", help="button name, or vertical wheel ticks for scroll")
    ptr.add_argument("x2", nargs="?", type=float, help="destination global logical x coordinate for drag")
    ptr.add_argument("y2", nargs="?", type=float, help="destination global logical y coordinate for drag")
    ptr.add_argument("--dx", type=float, help="horizontal wheel ticks for scroll")
    ptr.add_argument("--duration", type=float, default=0.2, help="drag pacing duration in seconds")
    ptr.add_argument("--dispatcher", default="hypr-agent-protal:pointer")
    ptr.add_argument("--json", action="store_true")
    ptr.set_defaults(func=pointer)

    ind = sub.add_parser("indicator", help="show the agent cursor indicator without sending input")
    ind.add_argument("target", help="Hyprland window regex, for example address:0x1234")
    ind.add_argument("x", type=float, help="global logical x coordinate")
    ind.add_argument("y", type=float, help="global logical y coordinate")
    ind.add_argument("action", nargs="?", default="move", help="action label for cursor animation state")
    ind.add_argument("--dispatcher", default="hypr-agent-protal:indicator")
    ind.add_argument("--json", action="store_true")
    ind.set_defaults(func=indicator)

    key = sub.add_parser("keyboard", help="send keyboard input to a target window")
    key.add_argument("target", help="Hyprland window regex, for example address:0x1234")
    key.add_argument("action", choices=["tap", "press-release", "press", "down", "release", "up"])
    key.add_argument("key", help="key name or raw evdev keycode, for example enter, v, f5, 28")
    key.add_argument("modifiers", nargs="?", default="", help="optional modifiers, for example ctrl+shift")
    key.add_argument("--x", type=float, help="optional global logical x coordinate to resolve a subsurface")
    key.add_argument("--y", type=float, help="optional global logical y coordinate to resolve a subsurface")
    key.add_argument("--dispatcher", default="hypr-agent-protal:keyboard")
    key.add_argument("--json", action="store_true")
    key.set_defaults(func=keyboard)

    sess = sub.add_parser("session", help="begin, sync, or end a related-window workspace guard session")
    sess.add_argument("action", choices=["begin", "sync", "end"])
    sess.add_argument("target", nargs="?", help="Hyprland window regex, for example address:0x1234")
    sess.add_argument("--dispatcher", default="hypr-agent-protal:session")
    sess.add_argument("--json", action="store_true")
    sess.set_defaults(func=session)

    win = sub.add_parser("windows", help="list Hyprland windows")
    win.add_argument("--visible-workspace", action="store_true", help="only return clients on the active workspace")
    win.add_argument("--related-to", help="only return the selected window and same-process related windows")
    win.set_defaults(func=windows)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
